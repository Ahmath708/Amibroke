# Supabase
EXPO_PUBLIC_SUPABASE_URL=your_supabase_project_url
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# PostHog Analytics (optional)
EXPO_PUBLIC_POSTHOG_API_KEY=your_posthog_api_key
EXPO_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# RevenueCat (In-App Purchases) — public SDK key from the RevenueCat dashboard.
# For free local testing (no paid Apple account) use the Test Store key (test_…).
# For release you MUST use the App Store key (appl_…) — a test_ key is refused in
# production builds (see src/services/purchases.ts).
EXPO_PUBLIC_REVENUECAT_IOS_KEY=appl_your_revenuecat_ios_key
# EXPO_PUBLIC_REVENUECAT_ANDROID_KEY=goog_your_revenuecat_android_key

# Feature Flags
EXPO_PUBLIC_FEATURE_CREATOR_DASHBOARD=false

# --- Supabase Edge Function Secrets (set via `supabase secrets set`) ---
# These are NOT used client-side; they must be set in Supabase for edge functions.
# ANTHROPIC_API_KEY=sk-ant-...
# GROQ_API_KEY=gsk-...
# RATE_LIMIT_MAX_REQUESTS=10
# RATE_LIMIT_WINDOW_MS=60000
# SUPABASE_ACCESS_TOKEN=sb_access_token_for_ci
# RevenueCat webhook auth — shared secret checked by the revenuecat-webhook function.
# REVENUECAT_WEBHOOK_AUTH=some-long-random-string
